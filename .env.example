# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=diceapp_adobe
DB_PASSWORD=your_password
DB_NAME=mail_service
DB_CONNECTION_LIMIT=10
DB_ROOT_PASSWORD=your_root_password

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# AWS SES
SES_FROM_EMAIL=noreply@yourdomain.com
SES_REPLY_TO_EMAIL=
SES_CONFIGURATION_SET=

# AWS SQS
SQS_EMAIL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/email-queue
SQS_BOUNCE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/bounce-queue

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=24h

# Worker
WORKER_POLL_INTERVAL=5000
WORKER_MAX_MESSAGES=10
WORKER_RETRY_ATTEMPTS=3
WORKER_RETRY_DELAY=30000
WORKER_CONCURRENCY=5

# CORS
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
